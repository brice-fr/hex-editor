{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hex-editor",
  "version": "0.2.4",
  "identifier": "com.brice-dev.hex-editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "hex-editor",
        "width": 925,
        "height": 460
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["hex", "ihex"],
        "name": "Intel HEX File",
        "description": "Intel HEX firmware file",
        "mimeType": "text/x-ihex",
        "role": "Editor"
      },
      {
        "ext": ["srec", "s19", "s28", "s37", "mot"],
        "name": "Motorola S-Record",
        "description": "Motorola S-Record firmware file",
        "mimeType": "text/x-srecord",
        "role": "Editor"
      }
    ]
  }
}
